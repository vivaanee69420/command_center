# Server
JWT_SECRET=change-me-to-a-real-32-byte-random-string
TOKEN_TTL_HOURS=12
CORS_ORIGINS=http://localhost:9100,http://127.0.0.1:9100,http://localhost:3000

# DB / cache
DATABASE_URL=postgresql+asyncpg://commandos:commandos_dev@localhost:5432/commandos
REDIS_URL=redis://localhost:6379/0

# Encryption (for stored OAuth tokens)
TOKEN_ENC_KEY=                 # 32-byte base64 — generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"

# AI Brain
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_BRAIN_MODEL=claude-sonnet-4-5
AI_BRAIN_INTERVAL_MIN=60       # how often the directive worker runs

# Google (Ads · Calendar · Gmail · Search Console · Analytics)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8765/api/integrations/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Meta (Facebook + Instagram Ads)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8765/api/integrations/meta/callback
META_SYSTEM_USER_TOKEN=        # long-lived alternative to OAuth

# GoHighLevel — one entry per sub-account, comma-separated key=value
GHL_TOKENS=ashford=,rochester=,barnet=,fts=,warwick_lodge=,plan4growth=,elevate=,lab=

# Dentally
DENTALLY_API_KEY=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# SEO
AHREFS_API_KEY=
SEMRUSH_API_KEY=

# Voice / TTS
ELEVENLABS_API_KEY=
BLAND_API_KEY=

# Email (transactional)
SENDGRID_API_KEY=
SENDER_EMAIL=
